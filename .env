# ==================== Environment Configuration ====================
# Copy this file to .env and fill in your values

# ==================== Application ====================
ENV=development

# ==================== Service API Key (for inter-service communication) ====================
# Generate a strong secret key! openssl rand -hex 32
SERVICE_API_KEY=change-this-in-production

# ==================== PostgreSQL - Auth Service ====================
POSTGRES_USER=cloudstorage
POSTGRES_PASSWORD=cloudstorage_secret
POSTGRES_DB_AUTH=cloudstorage_auth

# ==================== PostgreSQL - File Service ====================
POSTGRES_DB_FILE=cloudstorage_file

# ==================== MinIO ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_BUCKET=cloudstorage

# ==================== Redis ====================
REDIS_PASSWORD=redis_secret_123

# ==================== JWT ====================
# Generate a strong secret key for production!
# openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ==================== Email (SMTP) ====================
# For development, use Mailtrap (https://mailtrap.io/)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@cloudstorage.local

# ==================== Frontend ====================
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080/api

# ==================== Storage Quotas (in bytes) ====================
DEFAULT_STORAGE_QUOTA=5368709120      # 5 GB
PREMIUM_STORAGE_QUOTA=107374182400    # 100 GB
