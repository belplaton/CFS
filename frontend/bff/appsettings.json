{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BackendServices": {
    "Mode": "Remote",
    "Auth": {
      "BaseUrl": "http://localhost:8081",
      "LoginPath": "/api/auth/login",
      "CurrentUserPath": "/api/auth/me"
    },
    "Files": {
      "BaseUrl": "http://localhost:8082",
      "RootPath": "/api/files/root",
      "CreateFolderPath": "/api/folders"
    },
    "Storage": {
      "BaseUrl": "http://localhost:8083"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5180",
      "http://localhost:7080"
    ]
  },
  "UseMockGateways": true
}
