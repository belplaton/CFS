@inherits LayoutComponentBase
@inject SessionState SessionState
@inject SessionCoordinator SessionCoordinator

<div class="page-shell">
    <aside class="sidebar-shell">
        <NavMenu />
    </aside>

    <main class="main-shell">
        <header class="top-row">
            <div>
                <p class="stack-label">Cloud File Storage</p>
                <h2>Frontend + BFF starter</h2>
            </div>

            <div class="top-row-actions">
                <span class="status-pill">@GetSessionBadge()</span>

                @if (SessionState.IsAuthenticated && SessionState.User is not null)
                {
                    <div class="user-chip">
                        <span class="user-chip-label">Signed in</span>
                        <strong>@SessionState.User.DisplayName</strong>
                    </div>

                    <button class="ghost-link ghost-button" type="button" @onclick="HandleSignOutAsync">Sign out</button>
                }
                else
                {
                    <a class="ghost-link" href="login">Open login</a>
                }
            </div>
        </header>

        @if (SessionState.Notice is not null)
        {
            <div class="notice layout-notice @GetNoticeClass(SessionState.Notice.Level)">
                <div>
                    <strong>@GetNoticeTitle(SessionState.Notice.Level)</strong>
                    <div>@SessionState.Notice.Message</div>
                </div>

                <button class="ghost-button" type="button" @onclick="SessionState.ClearNotice">
                    Dismiss
                </button>
            </div>
        }

        <article class="content-shell">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task HandleSignOutAsync()
    {
        await SessionCoordinator.SignOutAsync();
    }

    private string GetSessionBadge() =>
        SessionState.IsRestoring
            ? "Checking session"
            : SessionState.IsAuthenticated
                ? "Session active"
                : "Guest mode";

    private static string GetNoticeClass(SessionNoticeLevel level) =>
        level switch
        {
            SessionNoticeLevel.Warning => "notice-warning",
            SessionNoticeLevel.Error => "notice-danger",
            _ => "notice-info"
        };

    private static string GetNoticeTitle(SessionNoticeLevel level) =>
        level switch
        {
            SessionNoticeLevel.Warning => "Session warning",
            SessionNoticeLevel.Error => "Session error",
            _ => "Session update"
        };
}
