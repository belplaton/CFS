@implements IDisposable
@inject SessionState SessionState
@inject SessionCoordinator SessionCoordinator
@inject CfsApiClient ApiClient

@if (!SessionState.IsReady)
{
    <PageTitle>CFS Frontend</PageTitle>

    <div class="app-bootstrap-shell">
        <section class="surface-card app-bootstrap-card">
            <p class="stack-label">Session bootstrap</p>
            <h1>Restoring the browser session</h1>
            <p class="app-bootstrap-copy">
                Checking persisted auth state and validating the current bearer token with the BFF
                before rendering the workspace shell.
            </p>
        </section>
    </div>
}
else
{
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
}

@code {
    protected override void OnInitialized()
    {
        SessionState.Changed += HandleSessionStateChanged;
        SessionState.BeginRestore();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var storedSession = await SessionCoordinator.GetStoredSessionAsync();
            if (storedSession is null)
            {
                return;
            }

            if (storedSession.ExpiresAtUtc <= DateTimeOffset.UtcNow)
            {
                await SessionCoordinator.SignOutAsync(
                    "Saved session expired. Sign in again.",
                    SessionNoticeLevel.Info);
                return;
            }

            await SessionCoordinator.SignInAsync(storedSession);

            var user = await ApiClient.GetCurrentUserAsync();
            if (user is not null)
            {
                await SessionCoordinator.UpdateUserAsync(user);
            }
        }
        catch (ApiClientException exception) when (exception.IsServiceUnavailable)
        {
            SessionState.SetNotice(
                "Could not verify the saved session because the BFF is unavailable.",
                SessionNoticeLevel.Warning);
        }
        catch (Exception)
        {
            await SessionCoordinator.SignOutAsync(
                "Could not restore the saved session.",
                SessionNoticeLevel.Warning);
        }
        finally
        {
            SessionState.CompleteRestore();
        }
    }

    private void HandleSessionStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionState.Changed -= HandleSessionStateChanged;
    }
}
