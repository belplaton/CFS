# Caddy Gateway Configuration
#
# Local development runs over plain HTTP on :80.  In production this
# file is meant to be replaced (or extended) with an HTTPS-enabled
# block that enables HSTS — see the prod block at the bottom.

http://:80 {
    # Log all requests
    log {
        output stdout
        format console
        level info
    }

    # ==================== Security headers (Phase 2.8) ====================
    # Applied to every response.  These are no-ops for non-browser
    # clients (curl, mobile apps) and harmless for the SPA.
    header {
        # Don't let browsers/old proxies second-guess our Content-Type.
        X-Content-Type-Options "nosniff"
        # Clickjacking protection for any HTML we ever serve.
        X-Frame-Options "DENY"
        # Don't leak referrers to third-party origins.
        Referrer-Policy "no-referrer"
        # Disable powerful APIs we never use.
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Conservative CSP for the JSON API: we never inline anything,
        # and we explicitly do not allow the response to be embedded
        # anywhere.  The frontend has its own CSP in nginx.conf.
        Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
        # Don't cache responses that may contain user data.
        Cache-Control "no-store"
        # Cross-origin isolation primitives for browsers.
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
        # Strip the Server header so we don't leak Caddy version.
        -Server
    }

    # CORS headers for API
    @api {
        path /api/*
    }
    handle @api {
        header Access-Control-Allow-Origin "http://localhost:8080"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Key"
        header Access-Control-Allow-Credentials "true"
        header Access-Control-Max-Age "86400"
    }

    # Auth Service API
    handle /api/auth/* {
        reverse_proxy auth:8000
    }

    # File Service API
    handle /api/files/* {
        reverse_proxy file:8000
    }

    # Preview Service API
    handle /api/preview/* {
        reverse_proxy preview:8000
    }

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Frontend (React app) - proxy to nginx container
    handle /* {
        reverse_proxy frontend:80
    }
}

# ==================== Production HTTPS block (template) ====================
#
# In production replace the block above with the one below.  Caddy
# will obtain a Let's Encrypt certificate automatically and enable
# HSTS preload.
#
# your-domain.example.com {
#     header {
#         Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
#         # ... plus all of the headers from the dev block above
#     }
#     # same handle directives as above
# }

