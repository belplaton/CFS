# Caddy Gateway Configuration
#
# Local development runs over plain HTTP on :80.  In production this
# file is meant to be replaced (or extended) with an HTTPS-enabled
# block that enables HSTS — see the prod block at the bottom.

http://:80 {
    # Log all requests
    log {
        output stdout
        format console
        level info
    }

    # ==================== Security headers (Phase 2.8) ====================
    # Safe defaults shared by SPA and API responses.
    header {
        # Don't let browsers/old proxies second-guess our Content-Type.
        X-Content-Type-Options "nosniff"
        # Clickjacking protection for any HTML we ever serve.
        X-Frame-Options "DENY"
        # Don't leak referrers to third-party origins.
        Referrer-Policy "no-referrer"
        # Disable powerful APIs we never use.
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Strip the Server header so we don't leak Caddy version.
        -Server
    }

    # CORS + browser headers for API responses (except binary file downloads)
    @api path /api/* !path /api/files/*/download
    header @api {
        Access-Control-Allow-Origin "http://localhost:8080"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Key"
        Access-Control-Allow-Credentials "true"
        Access-Control-Max-Age "86400"
        # API responses are JSON/plain-text only. Keep them out of caches and embeddings.
        Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
        Cache-Control "no-store"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
    }

    # Swagger / OpenAPI passthrough
    handle /docs/auth {
        reverse_proxy auth:8000
    }
    handle /redoc/auth {
        reverse_proxy auth:8000
    }
    handle /openapi/auth.json {
        reverse_proxy auth:8000
    }

    handle /docs/file {
        reverse_proxy file:8000
    }
    handle /redoc/file {
        reverse_proxy file:8000
    }
    handle /openapi/file.json {
        reverse_proxy file:8000
    }

    handle /docs/preview {
        reverse_proxy preview:8000
    }
    handle /redoc/preview {
        reverse_proxy preview:8000
    }
    handle /openapi/preview.json {
        reverse_proxy preview:8000
    }

    # Auth Service API
    @auth_api path /api/auth /api/auth/*
    handle @auth_api {
        reverse_proxy auth:8000
    }

    # File Service API  (* = one segment, */* = two segments e.g. /api/files/{id}/download)
    @file_api path /api/files /api/files/* /api/files/*/* /api/folders /api/folders/* /api/trash /api/trash/* /api/trash/*/* /api/search /api/search/*
    handle @file_api {
        reverse_proxy file:8000
    }

    # Preview Service API  (*/  handles /api/preview/{id}/thumbnail etc.)
    @preview_api path /api/preview /api/preview/* /api/preview/*/*
    handle @preview_api {
        reverse_proxy preview:8000
    }

    # Health endpoints
    handle /health/auth {
        rewrite * /health
        reverse_proxy auth:8000
    }
    handle /health/file {
        rewrite * /health
        reverse_proxy file:8000
    }
    handle /health/preview {
        rewrite * /health
        reverse_proxy preview:8000
    }
    handle /health {
        rewrite * /health
        reverse_proxy file:8000
    }

    # Frontend (React app) - proxy to nginx container
    handle /* {
        reverse_proxy frontend:80
    }
}

# ==================== Production HTTPS block (template) ====================
#
# In production replace the block above with the one below.  Caddy
# will obtain a Let's Encrypt certificate automatically and enable
# HSTS preload.
#
# your-domain.example.com {
#     header {
#         Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
#         # ... plus all of the headers from the dev block above
#     }
#     # same handle directives as above
# }

