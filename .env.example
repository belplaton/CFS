# ===========================================
# CFS - Cloud File Storage Environment Variables
# ===========================================

# -------------------------------------------
# PostgreSQL Database
# -------------------------------------------
POSTGRES_USER=cfs_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=cfs_database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection string (generated from above values)
# DATABASE_URL=postgresql://cfs_user:your_secure_password_here@postgres:5432/cfs_database?sslmode=disable

# -------------------------------------------
# MinIO Object Storage
# -------------------------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_BUCKET=cfs-files

# MinIO endpoint (internal for Docker, external for local dev)
MINIO_ENDPOINT=minio:9000
MINIO_ENDPOINT_EXTERNAL=localhost:9000

# MinIO access credentials for application
MINIO_ACCESS_KEY=minio_app_access_key
MINIO_SECRET_KEY=minio_app_secret_key

# Enable HTTPS for MinIO (false for local development)
MINIO_USE_SSL=false

# -------------------------------------------
# Auth Service Configuration
# -------------------------------------------
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8081

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Auth Service URLs
AUTH_SERVICE_URL=http://auth-service:8081

# -------------------------------------------
# File Service Configuration
# -------------------------------------------
FILE_SERVICE_HOST=0.0.0.0
FILE_SERVICE_PORT=8082

# File Service URLs
FILE_SERVICE_URL=http://file-service:8082

# Storage Service URL (for internal communication)
STORAGE_SERVICE_URL=http://storage-service:8083

# -------------------------------------------
# Storage Service Configuration
# -------------------------------------------
STORAGE_SERVICE_HOST=0.0.0.0
STORAGE_SERVICE_PORT=8083

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# -------------------------------------------
# Nginx Configuration
# -------------------------------------------
NGINX_HOST=0.0.0.0
NGINX_PORT=80
NGINX_SSL_PORT=443

# SSL Certificates (for production)
# SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
# SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -------------------------------------------
# Environment Mode
# -------------------------------------------
ENVIRONMENT=development
# ENVIRONMENT=production
